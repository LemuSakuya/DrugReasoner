# DeepBindDTA local environment template
# Copy this file to .env and replace placeholder values for your machine.

# MySQL / Docker
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=drug_discovery
MYSQL_PORT=3306

# Application database connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=drug_discovery

# Option A: DeepSeek / OpenAI-compatible chat completions endpoint
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_THINKING=disabled
LLM_REASONING_EFFORT=

# Option B: LangChain provider model, for example openai:gpt-4o-mini
LLM_PROVIDER_MODEL=
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
